@@ -0,0 +1,17 @@
+import MLX
+
+// Backports APIs added after the pinned Prism MLX Swift revision.
+extension DType {
+    public var greatestFiniteMagnitudeArray: MLXArray {
+        guard let info = finfo else {
+            fatalError("greatestFiniteMagnitudeArray requires a floating-point dtype, got \(self)")
+        }
+        return MLXArray(info.max, dtype: self)
+    }
+}
+
+extension MLXArray {
+    public static func maskFill(for dtype: DType) -> MLXArray {
+        return -dtype.greatestFiniteMagnitudeArray
+    }
+}

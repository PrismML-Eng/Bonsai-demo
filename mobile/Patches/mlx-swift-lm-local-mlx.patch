+
+public enum ReasoningBudgetError: LocalizedError, Sendable {
+    case missingEndDelimiter
+    case endDelimiterIsNotSingleToken(String)
+
+    public var errorDescription: String? {
+        switch self {
+        case .missingEndDelimiter:
+            "A positive reasoning budget requires a configured reasoning end delimiter."
+        case .endDelimiterIsNotSingleToken(let delimiter):
+            "The reasoning end delimiter must encode to exactly one token: \(delimiter)"
+        }
+    }
+}
+
+public struct ReasoningBudgetDebugSnapshot: Equatable, Sendable {
+    public let reasoningBudget: Int
+    public let sampledReasoningTokenCount: Int
+    public let forcedCloseTokenIndex: Int?
+    public let didSampleForcedClose: Bool
+}
+
+/// Thread-safe instrumentation shared between a chat session and the value-type
+/// logit processor copied into its token iterator.
+public final class ReasoningBudgetTelemetry: @unchecked Sendable {
+    private let lock = NSLock()
+    private var reasoningBudget = -1
+    private var sampledReasoningTokenCount = 0
+    private var forcedCloseTokenIndex: Int?
+    private var didSampleForcedClose = false
+
+    public init() {}
+
+    public var snapshot: ReasoningBudgetDebugSnapshot {
+        lock.withLock {
+            ReasoningBudgetDebugSnapshot(
+                reasoningBudget: reasoningBudget,
+                sampledReasoningTokenCount: sampledReasoningTokenCount,
+                forcedCloseTokenIndex: forcedCloseTokenIndex,
+                didSampleForcedClose: didSampleForcedClose)
+        }
+    }
+
+    func reset(budget: Int) {
+        lock.withLock {
+            reasoningBudget = budget
+            sampledReasoningTokenCount = 0
+            forcedCloseTokenIndex = nil
+            didSampleForcedClose = false
+        }
+    }
+
+    func recordReasoningToken(count: Int) {
+        lock.withLock { sampledReasoningTokenCount = count }
+    }
+
+    func recordForcedClose(at tokenIndex: Int) {
+        lock.withLock {
+            if forcedCloseTokenIndex == nil { forcedCloseTokenIndex = tokenIndex }
+        }
+    }
+
+    func recordSampledForcedClose() {
+        lock.withLock { didSampleForcedClose = true }
+    }
+}
+
+/// Composes an existing processor with a token-accurate reasoning budget. Once
+/// the budget is exhausted, exactly the configured close-delimiter token is
+/// forced and normal answer generation resumes.
+public struct ReasoningBudgetProcessor: LogitProcessor {
+    private var upstream: LogitProcessor?
+    private let budget: Int
+    private let endTokenID: Int
+    private let telemetry: ReasoningBudgetTelemetry
+    private var reasoningTokenCount = 0
+    private var didClose = false
+
+    public init(
+        upstream: LogitProcessor?, budget: Int, endTokenID: Int,
+        telemetry: ReasoningBudgetTelemetry
+    ) {
+        self.upstream = upstream
+        self.budget = budget
+        self.endTokenID = endTokenID
+        self.telemetry = telemetry
+    }
+
+    mutating public func prompt(_ prompt: MLXArray) {
+        reasoningTokenCount = 0
+        didClose = false
+        telemetry.reset(budget: budget)
+        upstream?.prompt(prompt)
+    }
+
+    public func process(logits: MLXArray) -> MLXArray {
+        let processed = upstream?.process(logits: logits) ?? logits
+        guard !didClose, reasoningTokenCount >= budget else { return processed }
+        telemetry.recordForcedClose(at: reasoningTokenCount)
+        let masked = MLXArray.full(
+            processed.shape,
+            values: MLXArray.maskFill(for: processed.dtype),
+            dtype: processed.dtype
+        )
+        return masked.at[0..., endTokenID].add(-MLXArray.maskFill(for: processed.dtype))
+    }
+
+    mutating public func didSample(token: MLXArray) {
+        upstream?.didSample(token: token)
+        guard !didClose else { return }
+        if token.item(Int.self) == endTokenID {
+            if reasoningTokenCount >= budget {
+                telemetry.recordSampledForcedClose()
+            }
+            didClose = true
+        } else {
+            reasoningTokenCount += 1
+            telemetry.recordReasoningToken(count: reasoningTokenCount)
+        }
+    }
+}
